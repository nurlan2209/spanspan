PORT=5000

# PostgreSQL connection string
DATABASE_URL=postgresql://ortus:change_me@postgres:5432/ortus

# Used by docker-compose to set postgres container password — must match DATABASE_URL
POSTGRES_DB=ortus
POSTGRES_USER=ortus
POSTGRES_PASSWORD=change_me

JWT_SECRET=change_me
JWT_EXPIRE=30d

# Public base URL for uploaded file links (no trailing slash)
# Example: https://api.yourdomain.com
BASE_URL=http://localhost:5000

# Comma-separated allowed web origins for credentialed requests.
# Example: CORS_ORIGINS=http://localhost:3000,https://app.example.com
CORS_ORIGINS=
